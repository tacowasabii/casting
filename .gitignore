# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js (.next-dist = NAS 이슈로 변경된 distDir, .next-stale*/.next-ghost* = SMB 락 잔해)
/.next*/
/out/

# NAS SMB delete-pending 잔해 (라우트 트리 밖으로 옮겨둔 삭제 대기 디렉터리)
/.trash-*/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
